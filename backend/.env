# DynoBackend Environment Configuration
PORT=8001
API_SERVICE_PORT=3301

# PostgreSQL Configuration
DB_NAME=dyno_db
USER_NAME=postgres
PASSWORD=postgres
HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_PUBLIC_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=your-jwt-secret-key-here
ACCESS_TOKEN_SECRET=your-access-token-secret-here

# API Secret for encryption
API_SECRET=your-api-secret-key-here

# Server URLs (internal communication)
SERVER_URL=http://localhost:8001
CHECKOUT_URL=http://localhost:3000

# CORS Origins
CORS_ORIGINS="*"
